rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
        : null;
    }

    function hasUserDoc() {
      return signedIn() && userDoc().data != null;
    }

    function isInternalUser() {
      return hasUserDoc()
        && (
          userDoc().data.rol == 'admin'
          || userDoc().data.rol == 'colaborador'
        );
    }

    function isPartner() {
      return hasUserDoc()
        && (
          userDoc().data.rol == 'broker'
          || userDoc().data.rol == 'agency'
        );
    }

    function bookingDoc(bookingId) {
      return firestore.get(/databases/(default)/documents/bookings/$(bookingId));
    }

    function canManageBookingLicense(bookingId) {
      return isInternalUser()
        || (
          isPartner()
          && bookingDoc(bookingId).data != null
          && (
            bookingDoc(bookingId).data.broker_id == request.auth.uid
            || bookingDoc(bookingId).data.agency_id == request.auth.uid
            || bookingDoc(bookingId).data.creado_por == request.auth.uid
          )
        );
    }

    // Product catalog images are public-read, internal-user-write.
    match /products/{productId}/{fileName} {
      allow read: if true;
      allow write: if isInternalUser();
    }

    // Commission docs (invoices/receipts) are internal-only.
    match /commission-documents/{partnerId}/{fileName} {
      allow read, write: if isInternalUser();
    }

    // Nautical license attachments are visible/editable by staff and the related broker/agency.
    match /bookings/{bookingId}/nautical-license/{fileName} {
      allow read, write: if canManageBookingLicense(bookingId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
